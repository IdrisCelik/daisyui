2,85,88,89,92,95,96,99,102,105,108,111,112,120,122,125,128,129,131,135,139,143,147,151,155,159,163,167,171,175,179,180,182,190,193,196,199,202,206,209,212,213,216,219,222,226,229,232,235,238,241,244,247,250,253,256,259,262,265,268,271,274,275,278,281,284,287,290,293,296,299,302,305,306,309,312,315,318,321,324,327,330,331,334,337,340,343,346,349,352,355,358,361,364,367,370,373,376,379,380,383,386,389,392,395,398,401,404,407,408,411,414,417,420,426,428,429,432,435,438,441,443,446,449,450],[456,457,458,459,460,461,462,463,464,465,466,467,468,469,470,471,472,473,474,475,476,477,478,479,480,481,482,483,484,485,486,487,488,489,490],"light","dark","cupcake","bumblebee","emerald","corporate","synthwave","retro","cyberpunk","valentine","halloween","garden","forest","aqua","lofi","pastel","fantasy","wireframe","black","luxury","dracula","cmyk","autumn","business","acid","lemonade","night","coffee","winter","dim","nord","sunset","caramellatte","abyss","silk","5.7.0",41711],"uses":{}},{"type":"data","data":[{"pages":1},[]],"uses":{"url":1}},{"type":"data","data":[{"first":1,"second":62,"attributeRules":114,"libraries":117},{"name":2,"intro":3,"touse":4,"nottouse":5,"logo":6,"attributes":7,"key":61},"Meraki UI","Meraki UI is an open-source collection of Tailwind CSS components and templates. It offers a range of pre-designed UI elements and layouts that can be used to quickly build web interfaces.","Use Meraki UI when you want to accelerate your Tailwind CSS development process with a set of pre-designed components and templates. It's suitable for projects where you want to quickly prototype or build web interfaces with a consistent design.","Avoid Meraki UI if you require a component library with extensive customization options or highly specific designs. Also, if you prefer a component library with built-in theming capabilities, Meraki UI might not be the best choice.","\u003Csvg viewBox=\"0 0 106 104\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\u003Cpath d=\"M13.7393 76.3241L3.41309 86.6338C2.15269 87.8921 0 86.9995 0 85.2184V59.488C0 57.7067 2.15331 56.8141 3.41352 58.0731L13.7393 68.3887C14.262 68.9093 14.6767 69.5277 14.9597 70.2086C15.2427 70.8894 15.3883 71.6193 15.3883 72.3564C15.3883 73.0935 15.2427 73.8234 14.9597 74.5042C14.6767 75.1851 14.262 75.8035 13.7393 76.3241Z\" fill=\"#2563eb\">\u003C/path>\u003Cpath d=\"M91.3683 76.3241L101.694 86.6337C102.955 87.8921 105.108 86.9995 105.108 85.2184V59.488C105.108 57.7067 102.954 56.8141 101.694 58.0731L91.3683 68.3887C90.8456 68.9093 90.4309 69.5277 90.1479 70.2086C89.8649 70.8894 89.7192 71.6193 89.7192 72.3564C89.7192 73.0935 89.8649 73.8234 90.1479 74.5042C90.4309 75.1851 90.8456 75.8035 91.3683 76.3241Z\" fill=\"#2563eb\">\u003C/path>\u003Cpath d=\"M49.7091 54.6385L6.82642 11.8167C4.30574 9.29962 0 11.0849 0 14.6471V33.0139C0 34.076 0.422407 35.0945 1.1741 35.8449L44.8945 79.4874C46.9238 81.5064 49.6719 82.6402 52.5368 82.6402C55.4017 82.6402 58.1498 81.5064 60.1791 79.4874L103.932 35.8536C104.685 35.1031 105.108 34.084 105.108 33.0213V14.6545C105.108 11.0924 100.802 9.30703 98.2813 11.8238L55.3984 54.6385C54.6437 55.3912 53.6205 55.814 52.5538 55.814C51.487 55.814 50.4638 55.3912 49.7091 54.6385Z\" fill=\"#2563eb\">\u003C/path>\u003C/svg>",{"License":8,"Frameworks":11,"Unique components":15,"Built-in Themes":18,"Supports more than two themes":21,"JavaScript size":25,"Dependencies":28,"Dependency size":31,"GitHub stars":32,"Used by open source projects":35,"NPM downloads":38,"CDN":39,"Semantic class names":42,"Global customizations":44,"works without Node.js":46,"No-build version":48,"P3 colors":50,"RTL support":52,"Runtime CSS customization":54,"Native CSS nesting":56,"Open GitHub issues":58},{"value":9,"desc":10},"MIT","Open source MIT License",{"value":12,"positive":13,"desc":14},"ALL",true,"Meraki UI is framework agnostic and works everywhere",{"value":16,"desc":17},18,"Meraki UI has 31 Components, 18 of them are unique – for example pagination and button group are considered as same.",{"value":19,"desc":20},2,"Meraki UI has light and dark themes",{"value":22,"positive":23,"desc":24},"No",false,"Does not support more than 2 themes at the same time",{"value":26,"positive":23,"desc":27},"17kB","Meraki UI requires Alpine.js",{"value":29,"positive":13,"desc":30},0,"Meraki UI has no dependencies, but it requires Alpine.js",{"value":29,"positive":13,"desc":30},{"value":33,"desc":34},2600,null,{"value":36,"desc":37},"?","Can't measure",{"value":36,"desc":37},{"value":40,"positive":13,"desc":41},"Yes","Meraki UI uses Tailwind CSS class names which is available on CDN",{"value":22,"positive":23,"desc":43},"Meraki UI does not use semantic CSS class names. Using semantic and descriptive CSS class names improves readability and maintainability of code independent of the current framework.",{"value":22,"positive":23,"desc":45},"Meraki UI requires changing class names one by one at build time to do customization",{"value":40,"positive":13,"desc":47},"Meraki UI does not requires a Node.js environment",{"value":22,"positive":23,"desc":49},"Meraki UI does not provide micro CSS files for each component",{"value":22,"positive":23,"desc":51},"Meraki UI does not use wide-gamut P3 colors by default",{"value":40,"positive":13,"desc":53},"Meraki UI supports right-to-left (RTL) layouts",{"value":22,"positive":23,"desc":55},"Meraki UI customizations requires changing Tailwind CSS class names at build time",{"value":22,"positive":23,"desc":57},"Meraki UI doesn not use native CSS nesting",{"value":59,"desc":60},3,"As of June 2026","merakiui",{"name":63,"intro":64,"touse":65,"nottouse":66,"logo":67,"attributes":68,"key":113},"Tailwind Plus","Tailwind Plus is a collection of professionally designed, pre-built UI components built with Tailwind CSS. It's a commercial product, offering a range of application layouts, marketing sections, and component examples. However, some components are only available for React and Vue.","Consider Tailwind Plus when you need high-quality, visually appealing UI components and have a project built with React or Vue (for some components). It's suitable for projects where you want to save time on design and front-end development by using pre-made components.","Avoid Tailwind Plus if you're working on a project with a different framework other than React or Vue, or if you require extensive customization beyond what the components offer. Also, if you prefer open-source solutions or have a limited budget, Tailwind Plus might not be the right choice due to its paid license.","\u003Csvg viewBox=\"0 0 176 21\">\u003Cpath fill=\"oklch(74.6% .16 232.661)\" d=\"M17.183 0C12.6 0 9.737 2.291 8.59 6.873c1.719-2.29 3.723-3.15 6.014-2.577 1.307.326 2.242 1.274 3.275 2.324 1.685 1.71 3.635 3.689 7.894 3.689 4.582 0 7.445-2.291 8.591-6.872-1.718 2.29-3.723 3.15-6.013 2.576-1.308-.326-2.243-1.274-3.276-2.324C23.39 1.98 21.44 0 17.183 0ZM8.59 10.309C4.01 10.309 1.145 12.6 0 17.182c1.718-2.291 3.723-3.15 6.013-2.577 1.308.326 2.243 1.274 3.276 2.324 1.685 1.71 3.635 3.689 7.894 3.689 4.582 0 7.445-2.29 8.59-6.872-1.718 2.29-3.722 3.15-6.013 2.577-1.307-.327-2.242-1.276-3.276-2.325-1.684-1.71-3.634-3.689-7.893-3.689Z\" clip-rule=\"evenodd\" fill-rule=\"evenodd\">\u003C/path>\u003Cpath class=\"fill-current\" d=\"M51.547 8.688h-3v5.803c0 1.548 1.016 1.524 3 1.427v2.346c-4.015.483-5.611-.629-5.611-3.773V8.688H43.71V6.172h2.225V2.925l2.612-.774v4.021h2.998v2.516Zm11.43-2.516h2.61v12.092h-2.61v-1.741c-.92 1.28-2.346 2.055-4.233 2.055-3.288 0-6.021-2.78-6.021-6.36 0-3.603 2.733-6.36 6.021-6.36 1.886 0 3.313.774 4.233 2.032V6.172Zm-3.821 9.915c2.176 0 3.82-1.62 3.82-3.87 0-2.248-1.644-3.868-3.82-3.868-2.177 0-3.821 1.62-3.821 3.869s1.644 3.87 3.82 3.87ZM69.94 4.36a1.687 1.687 0 0 1-1.668-1.669c.002-.443.179-.868.491-1.18a1.662 1.662 0 0 1 2.354 0c.312.312.49.737.491 1.18 0 .895-.75 1.669-1.668 1.669Zm-1.306 13.905V6.172h2.612v12.092h-2.612Zm5.635 0V.609h2.611v17.654H74.27ZM93.834 6.172h2.757l-3.797 12.092h-2.563l-2.