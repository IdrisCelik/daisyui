 76.3241L3.41309 86.6338C2.15269 87.8921 0 86.9995 0 85.2184V59.488C0 57.7067 2.15331 56.8141 3.41352 58.0731L13.7393 68.3887C14.262 68.9093 14.6767 69.5277 14.9597 70.2086C15.2427 70.8894 15.3883 71.6193 15.3883 72.3564C15.3883 73.0935 15.2427 73.8234 14.9597 74.5042C14.6767 75.1851 14.262 75.8035 13.7393 76.3241Z\" fill=\"#2563eb\">\u003C/path>\u003Cpath d=\"M91.3683 76.3241L101.694 86.6337C102.955 87.8921 105.108 86.9995 105.108 85.2184V59.488C105.108 57.7067 102.954 56.8141 101.694 58.0731L91.3683 68.3887C90.8456 68.9093 90.4309 69.5277 90.1479 70.2086C89.8649 70.8894 89.7192 71.6193 89.7192 72.3564C89.7192 73.0935 89.8649 73.8234 90.1479 74.5042C90.4309 75.1851 90.8456 75.8035 91.3683 76.3241Z\" fill=\"#2563eb\">\u003C/path>\u003Cpath d=\"M49.7091 54.6385L6.82642 11.8167C4.30574 9.29962 0 11.0849 0 14.6471V33.0139C0 34.076 0.422407 35.0945 1.1741 35.8449L44.8945 79.4874C46.9238 81.5064 49.6719 82.6402 52.5368 82.6402C55.4017 82.6402 58.1498 81.5064 60.1791 79.4874L103.932 35.8536C104.685 35.1031 105.108 34.084 105.108 33.0213V14.6545C105.108 11.0924 100.802 9.30703 98.2813 11.8238L55.3984 54.6385C54.6437 55.3912 53.6205 55.814 52.5538 55.814C51.487 55.814 50.4638 55.3912 49.7091 54.6385Z\" fill=\"#2563eb\">\u003C/path>\u003C/svg>",{"License":8,"Frameworks":11,"Unique components":15,"Built-in Themes":18,"Supports more than two themes":21,"JavaScript size":25,"Dependencies":28,"Dependency size":31,"GitHub stars":32,"Used by open source projects":35,"NPM downloads":38,"CDN":39,"Semantic class names":42,"Global customizations":44,"works without Node.js":46,"No-build version":48,"P3 colors":50,"RTL support":52,"Runtime CSS customization":54,"Native CSS nesting":56,"Open GitHub issues":58},{"value":9,"desc":10},"MIT","Open source MIT License",{"value":12,"positive":13,"desc":14},"ALL",true,"Meraki UI is framework agnostic and works everywhere",{"value":16,"desc":17},18,"Meraki UI has 31 Components, 18 of them are unique – for example pagination and button group are considered as same.",{"value":19,"desc":20},2,"Meraki UI has light and dark themes",{"value":22,"positive":23,"desc":24},"No",false,"Does not support more than 2 themes at the same time",{"value":26,"positive":23,"desc":27},"17kB","Meraki UI requires Alpine.js",{"value":29,"positive":13,"desc":30},0,"Meraki UI has no dependencies, but it requires Alpine.js",{"value":29,"positive":13,"desc":30},{"value":33,"desc":34},2600,null,{"value":36,"desc":37},"?","Can't measure",{"value":36,"desc":37},{"value":40,"positive":13,"desc":41},"Yes","Meraki UI uses Tailwind CSS class names which is available on CDN",{"value":22,"positive":23,"desc":43},"Meraki UI does not use semantic CSS class names. Using semantic and descriptive CSS class names improves readability and maintainability of code independent of the current framework.",{"value":22,"positive":23,"desc":45},"Meraki UI requires changing class names one by one at build time to do customization",{"value":40,"positive":13,"desc":47},"Meraki UI does not requires a Node.js environment",{"value":22,"positive":23,"desc":49},"Meraki UI does not provide micro CSS files for each component",{"value":22,"positive":23,"desc":51},"Meraki UI does not use wide-gamut P3 colors by default",{"value":40,"positive":13,"desc":53},"Meraki UI supports right-to-left (RTL) layouts",{"value":22,"positive":23,"desc":55},"Meraki UI customizations requires changing Tailwind CSS class names at build time",{"value":22,"positive":23,"desc":57},"Meraki UI doesn not use native CSS nesting",{"value":59,"desc":60},3,"As of June 2026","merakiui",{"name":63,"intro":64,"touse":65,"nottouse":66,"logo":67,"attributes":68,"key":114},"NuxtUI","Nuxt UI is a component library for Nuxt.js applications, providing a set of pre-built, customizable components designed to integrate seamlessly with the Nuxt framework. It offers a range of UI elements and tools for building modern web interfaces.","Use Nuxt UI when you're building Nuxt.js applications and want to leverage a component library specifically designed for the framework. It's suitable for projects that benefit from a consistent design system and tight integration with Nuxt.js features.","Avoid Nuxt UI if you're not using Nuxt.js, or if you need a component library that works with other frameworks. Also, consider the dependency size and the potential impact on your application's performance.","\u003Csvg viewBox=\"0 0 1020 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\u003Cpath d=\"M377 200C379.16 200 381 198.209 381 196V103C381 103 386 112 395 127L434 194C435.785 197.74 439.744 200 443 200H470V50H443C441.202 50 439 51.4941 439 54V148L421 116L385 55C383.248 51.8912 379.479 50 376 50H350V200H377Z\" fill=\"currentColor\">\u003C/path>\u003Cpath d=\"M726 92H739C742.314 92 745 89.3137 745 86V60H773V92H800V116H773V159C773 169.5 778.057 174 787 174H800V200H783C759.948 200 745 185.071 745 160V116H726V92Z\" fill=\"currentColor\">\u003C/path>\u003Cpath d=\"M591 92V154C591 168.004 585.742 179.809 578 188C570.258 196.191 559.566 200 545 200C530.434 200 518.742 196.191 511 188C503.389 179.809 498 168.004 498 154V92H514C517.412 92 520.769 92.622 523 95C525.231 97.2459 526 98.5652 526 102V154C526 162.059 526.457 167.037 530 171C533.543 174.831 537.914 176 545 176C552.217 176 555.457 174.831 559 171C562.543 167.037 563 162.059 563 154V102C563 98.5652 563.769 96.378 566 94C567.96 91.9107 570.028 91.9599 573 92C573.411 92.0055 574.586 92 575 92H591Z\" fill=\"currentColor\">\u003C/path>\u003Cpath d=\"M676 144L710 92H684C680.723 92 677.812 93.1758 676 96L660 120L645 97C643.188 94.1758 639.277 92 636 92H611L645 143L608 200H634C637.25 200 640.182 196.787 642 194L660 167L679 195C680.818 197.787 683.75 200 687 200H713L676 144Z\" fill=\"currentColor\">\u003C/path>\u003Cpath d=\"M168 200H279C282.542 200 285.932 198.756 289 197C292.068 195.244 295.23 193.041 297 190C298.77 186.959 300.002 183.51 300 179.999C299.998 176.488 298.773 173.04 297 170.001L222 41C220.23 37.96 218.067 35.7552 215 34