2,85,88,89,92,95,96,99,102,105,108,111,112,120,122,125,128,129,131,135,139,143,147,151,155,159,163,167,171,175,179,180,182,190,193,196,199,202,206,209,212,213,216,219,222,226,229,232,235,238,241,244,247,250,253,256,259,262,265,268,271,274,275,278,281,284,287,290,293,296,299,302,305,306,309,312,315,318,321,324,327,330,331,334,337,340,343,346,349,352,355,358,361,364,367,370,373,376,379,380,383,386,389,392,395,398,401,404,407,408,411,414,417,420,426,428,429,432,435,438,441,443,446,449,450],[456,457,458,459,460,461,462,463,464,465,466,467,468,469,470,471,472,473,474,475,476,477,478,479,480,481,482,483,484,485,486,487,488,489,490],"light","dark","cupcake","bumblebee","emerald","corporate","synthwave","retro","cyberpunk","valentine","halloween","garden","forest","aqua","lofi","pastel","fantasy","wireframe","black","luxury","dracula","cmyk","autumn","business","acid","lemonade","night","coffee","winter","dim","nord","sunset","caramellatte","abyss","silk","5.7.0",41711],"uses":{}},{"type":"data","data":[{"pages":1},[]],"uses":{"url":1}},{"type":"data","data":[{"first":1,"second":64,"attributeRules":116,"libraries":119},{"name":2,"intro":3,"touse":4,"nottouse":5,"logo":6,"attributes":7,"key":63},"Bootstrap","Bootstrap is a popular open-source CSS framework that provides a set of pre-built components, styles, and tools for building responsive web interfaces. It offers a wide range of UI elements and utilities for creating consistent and visually appealing websites and applications.","Use Bootstrap when you want a well-established and widely supported CSS framework with a large community and extensive documentation. It's suitable for projects where you need a responsive and consistent design system with a variety of customizable components.","Avoid Bootstrap if you prefer a more lightweight or utility-first CSS approach, or if you need a design that significantly deviates from the default Bootstrap styles. Also, consider the potential for CSS bloat and the need to override default styles for extensive customization.","\u003Csvg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 118 94\">\u003Cpath fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M24.509 0c-6.733 0-11.715 5.893-11.492 12.284.214 6.14-.064 14.092-2.066 20.577C8.943 39.365 5.547 43.485 0 44.014v5.972c5.547.529 8.943 4.649 10.951 11.153 2.002 6.485 2.28 14.437 2.066 20.577C12.794 88.106 17.776 94 24.51 94H93.5c6.733 0 11.714-5.893 11.491-12.284-.214-6.14.064-14.092 2.066-20.577 2.009-6.504 5.396-10.624 10.943-11.153v-5.972c-5.547-.529-8.934-4.649-10.943-11.153-2.002-6.484-2.28-14.437-2.066-20.577C105.214 5.894 100.233 0 93.5 0H24.508zM80 57.863C80 66.663 73.436 72 62.543 72H44a2 2 0 01-2-2V24a2 2 0 012-2h18.437c9.083 0 15.044 4.92 15.044 12.474 0 5.302-4.01 10.049-9.119 10.88v.277C75.317 46.394 80 51.21 80 57.863zM60.521 28.34H49.948v14.934h8.905c6.884 0 10.68-2.772 10.68-7.727 0-4.643-3.264-7.207-9.012-7.207zM49.948 49.2v16.458H60.91c7.167 0 10.964-2.876 10.964-8.281 0-5.406-3.903-8.178-11.425-8.178H49.948z\" fill=\"#712cf9\">\u003C/path>\u003C/svg>\n",{"License":8,"Frameworks":11,"Unique components":15,"Built-in Themes":18,"Supports more than two themes":21,"JavaScript size":25,"Dependencies":28,"Dependency size":31,"GitHub stars":33,"Used by open source projects":35,"NPM downloads":38,"CDN":41,"Semantic class names":44,"Global customizations":46,"works without Node.js":48,"No-build version":50,"P3 colors":52,"RTL support":54,"Runtime CSS customization":56,"Native CSS nesting":58,"Open GitHub issues":60},{"value":9,"desc":10},"MIT","Open source MIT License",{"value":12,"positive":13,"desc":14},"ALL",true,"Bootstrap is framework agnostic and works everywhere",{"value":16,"desc":17},28,"Bootstrap has 32 Components, 28 of them are unique – for example pagination and button group are considered as same.",{"value":19,"desc":20},2,"Bootstrap has light and dark themes",{"value":22,"positive":23,"desc":24},"No",false,"Does not support more than 2 themes at the same time",{"value":26,"positive":23,"desc":27},"24.6KB","JavaScript bundle size (minified)",{"value":29,"positive":13,"desc":30},0,"Bootstrap has no dependencies.",{"value":29,"positive":13,"desc":32},null,{"value":34,"desc":32},174000,{"value":36,"desc":37},6300000,"Based on GitHub's public repositories",{"value":39,"desc":40},4700000,"Weekly downloads from NPM",{"value":42,"positive":13,"desc":43},"Yes","Bootstrap CSS file is available on CDN",{"value":42,"positive":13,"desc":45},"Bootstrap uses semantic CSS class names. Using semantic and descriptive CSS class names improves readability and maintainability of code independent of the current framework.",{"value":42,"positive":13,"desc":47},"Bootstrap provides component-level CSS variables that let you adjust colors, sizes, spacing, radius, and other styles to match your design.",{"value":42,"positive":13,"desc":49},"Bootstrap does not require a Node.js environment",{"value":22,"positive":23,"desc":51},"Bootstrap does not provide micro CSS files for each component",{"value":22,"positive":23,"desc":53},"Bootstrap does not use wide-gamut P3 colors by default",{"value":42,"positive":13,"desc":55},"Bootstrap supports right-to-left (RTL) layouts",{"value":42,"positive":13,"desc":57},"Bootstrap uses CSS variables for design customization at runtime",{"value":22,"positive":23,"desc":59},"Bootstrap doesn not use native CSS nesting",{"value":61,"desc":62},158,"As of June 2026","bootstrap",{"name":65,"intro":66,"touse":67,"nottouse":68,"logo":69,"attributes":70,"key":115},"Bulma","Bulma is a free, open-source CSS framework based on Flexbox. It provides a set of pre-built components and styles for building responsive web interfaces.","Use Bulma when you want a simple, elegant, and easy-to-use CSS framework with a focus on clean and semantic HTML. It's suitable for projects where you need a responsive design system with a minimal learning curve.","Avoid Bulma if you require a component library with extensive JavaScript-based interactivity or adva